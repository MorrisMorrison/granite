# Granite self-hosting config. Copy to `.env` next to docker-compose.yml and fill in.
#   cp .env.example .env

# REQUIRED — signing secret for auth tokens (min 32 bytes). Generate one with:
#   openssl rand -base64 48
GRANITE_JWT_SECRET=

# Public URL your instance is reached at (used for links/CORS). No trailing slash.
# Behind a reverse proxy this is your https:// domain.
GRANITE_BASE_URL=http://localhost:8080

# Allow account signups. Leave false for a personal instance: the FIRST account can
# always be created (bootstrap), and further signups stay closed. Set true only if
# you want anyone to be able to register.
GRANITE_ALLOW_REGISTRATION=false

# Trust X-Forwarded-For/X-Real-IP for the client IP the rate limiter keys on.
# Set true ONLY behind a reverse proxy that REPLACES those headers; leave false
# when the port is exposed directly, or a client could spoof them past the limiter.
GRANITE_TRUSTED_PROXY=false

# Host port to expose (maps to the container's PORT). Change to avoid clashes.
GRANITE_PORT=8080

# Logging: debug | info | warn | error
GRANITE_LOG_LEVEL=info
