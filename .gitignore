# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# --- Secrets / env ---
.env
.env.*
!.env.example
*.local

# --- Node / SvelteKit (apps/mobile, packages/*) ---
node_modules/
.svelte-kit/
build/
dist/
.pnpm-store/
*.tsbuildinfo

# ...but keep ONLY the embedded web-app placeholder (the real build is copied in at
# image-build time and must stay ignored): un-ignore the dir, re-ignore its contents,
# then keep index.html.
!apps/api/internal/webui/dist/
apps/api/internal/webui/dist/*
!apps/api/internal/webui/dist/index.html

# --- Capacitor native projects (generated; build artifacts) ---
apps/mobile/android/
apps/mobile/ios/
!apps/mobile/android/.gitkeep
!apps/mobile/ios/.gitkeep

# --- Go (apps/api) ---
apps/api/bin/
apps/api/tmp/
*.exe
*.test
*.out
coverage.*
coverage/
junit.xml

# --- Local databases / dumps ---
*.sqlite
*.sqlite-*
*.db
*.db-wal
*.db-shm
*.dump

# Screenshots live on the dedicated `screenshots` branch, not main.
/docs/screenshots/
